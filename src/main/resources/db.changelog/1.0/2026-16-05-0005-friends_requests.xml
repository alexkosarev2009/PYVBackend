<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
       http://www.liquibase.org/xml/ns/dbchangelog
       http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.23.xsd">

    <changeSet id="2026-16-05-0005-friends_requests" author="akosarev">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="person"/>
        </preConditions>

        <createTable tableName="friends_requests">

            <column name="id" type="BIGSERIAL">
                <constraints primaryKey="true"/>
            </column>

            <column name="sender_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_sender_id"
                             referencedTableName="person"
                             referencedColumnNames="id"/>
            </column>

            <column name="receiver_id" type="BIGINT">
                <constraints nullable="false"
                             foreignKeyName="fk_receiver_id"
                             referencedTableName="person"
                             referencedColumnNames="id"/>
            </column>

            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>

        </createTable>

        <addUniqueConstraint
                tableName="friends_requests"
                columnNames="sender_id, receiver_id"
                constraintName="uq_friend_request_pair"/>

    </changeSet>

</databaseChangeLog>