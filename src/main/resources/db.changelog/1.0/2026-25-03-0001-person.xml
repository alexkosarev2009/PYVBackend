<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.8.xsd">

    <changeSet id="2026-25-03-0001-person" author="akosarev">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="person"/>
            </not>
        </preConditions>
        <createTable tableName="person">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="name" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="username" type="varchar">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="bio" type="varchar">
                <constraints nullable="true"/>
            </column>
            <column name="avatar_url" type="varchar">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </createTable>
    </changeSet>

    <changeSet id="2026-29-03-0002-email" author="akosarev">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="person"/>
            <not>
                <columnExists tableName="person" columnName="email"/>
            </not>
        </preConditions>
        <addColumn tableName="person">
            <column name="email" type="varchar">
                <constraints nullable="false" unique="true"/>
            </column>
        </addColumn>
    </changeSet>

    <changeSet id="2026-29-03-0003-password" author="akosarev">
        <preConditions onFail="MARK_RAN">
            <tableExists tableName="person"/>
            <not>
                <columnExists tableName="person" columnName="password"/>
            </not>
        </preConditions>
        <addColumn tableName="person">
            <column name="password" type="varchar">
                <constraints nullable="false"/>
            </column>
        </addColumn>
    </changeSet>
</databaseChangeLog>